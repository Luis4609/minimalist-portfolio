---
import Section from "@/components/Section.astro";

const { cv, lang } = Astro.props;
const { projects } = cv;

const title = lang === "es" ? "Proyectos" : "Projects";
const getLinkTitle = (name: string) => lang === "es" ? `Ver el proyecto ${name}` : `View the project ${name}`;
---

<Section title={title}>
  <ul>
    {
      projects.map(({ url, description, highlights, name, isActive }: any) => {
        return (
          <li>
            <article>
              <header>
                <h3>
                  <a href={url} title={getLinkTitle(name)} target="_blank" rel="noopener noreferrer">
                    {name}
                  </a>
                  {isActive && <span>&bull;</span>}
                </h3>
                <p>{description}</p>
              </header>
              <footer>
                {highlights.map((highlight: any) => {
                  return <span>{highlight}</span>;
                })}
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  article {
    border-radius: 8px;
    border: 1px solid #f2f2f2;
    gap: 16px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  article header {
    flex: 1;
  }

  article h3 {
    margin-bottom: 4px;
  }

  article h3 span {
    color: rgb(0, 188, 64) /* green */;
  }

  article p {
    font-size: 0.75rem;
    line-height: 1.2rem;
    margin-bottom: 4px;
  }
  article a {
    color: #111;
  }

  article a:hover {
    text-decoration: underline;
  }
  footer {
    gap: 4px;
    font-size: 0.6rem;
  }

  article footer {
    display: flex;
    flex-wrap: wrap;
  }

  footer span {
    border-radius: 6px;
    background: #eee;
    color: #444;
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    display: inline-flex;
  }
</style>
