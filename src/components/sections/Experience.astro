---
import Section from "@/components/Section.astro";

const { cv, lang } = Astro.props;
const { work } = cv;

const title = lang === "es" ? "Experiencia laboral" : "Work Experience";
---

<Section title={title}>
  <ul>
    {
      work.map(({ name, startDate, endDate, position, summary }: any) => {
        const startYear = startDate ? new Date(startDate).getFullYear() : "";
        let endYear = lang === "es" ? "Actualidad" : "Present";
        if (endDate) {
          if (endDate === "Actualidad" || endDate === "Present") {
            endYear = lang === "es" ? "Actualidad" : "Present";
          } else {
            const parsedEnd = new Date(endDate);
            endYear = isNaN(parsedEnd.getTime()) ? endDate : parsedEnd.getFullYear().toString();
          }
        }
        const years = startYear ? `${startYear} - ${endYear}` : endYear;

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{name}</h3>
                  <h4>{position}</h4>
                </div>

                <time>{years}</time>
              </header>
              <footer>
                <p>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: #111;
  }
  article h4 {
    font-weight: 400;
    color: #222;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    font-size: 0.85rem;
    color: #555;
  }
</style>
